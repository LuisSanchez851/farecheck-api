# ─── BASE DE DATOS ────────────────────────────────────
# Railway: copiar desde el panel de PostgreSQL del proyecto
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/farecheck"

# ─── SERVIDOR ─────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── FIREBASE ADMIN ───────────────────────────────────
# Firebase Console → Configuración del proyecto → Cuentas de servicio → Generar clave
FIREBASE_PROJECT_ID=farecheck-xxxxx
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@farecheck-xxxxx.iam.gserviceaccount.com
# La clave privada incluye saltos de línea — pegarla entre comillas con \n literales
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXXXX\n-----END PRIVATE KEY-----\n"

# ─── STRIPE ───────────────────────────────────────────
# dashboard.stripe.com → Desarrolladores → Claves API
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXX
STRIPE_PRICE_MENSUAL=price_XXXXXXXXXXXXXXXX
STRIPE_PRICE_ANUAL=price_XXXXXXXXXXXXXXXX

# ─── CLOUDINARY ───────────────────────────────────────
CLOUDINARY_CLOUD_NAME=farecheck
CLOUDINARY_API_KEY=XXXXXXXXXXXXXXXX
CLOUDINARY_API_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── SENTRY (S5-07) ───────────────────────────────────
SENTRY_DSN=

# ─── SEGURIDAD ────────────────────────────────────────
CORS_ORIGIN=*

# ─── TRIAL ────────────────────────────────────────────
TRIAL_DIAS=7

# ─── RATE LIMITING ────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
ANALISIS_RATE_LIMIT_MAX=200
